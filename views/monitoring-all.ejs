<%- include('partials/layout-open') %>

<div id="maRoot">
<div class="sm-card mb-3">
  <div class="sm-card-head">
    <span><i class="bi bi-grid-3x3-gap"></i> Monitoring All Servers</span>
    <span class="text-secondary small" id="maUpdated">—</span>
  </div>
  <div id="maActionResult" class="alert d-none py-2 mb-3" role="alert"></div>
  <div class="row g-2 align-items-end">
    <div class="col-12 col-md-4 col-lg-3">
      <label class="form-label small mb-1">Service</label>
      <select class="form-select form-select-sm" id="maService">
        <option value="nginx">Nginx</option>
        <option value="mysql">MySQL / MariaDB</option>
        <option value="redis">Redis</option>
        <option value="postfix">Postfix</option>
        <option value="openlitespeed">OpenLiteSpeed</option>
        <option value="lscpd">LSCPD (CyberPanel)</option>
      </select>
    </div>
    <div class="col-12 col-md-5 col-lg-4">
      <label class="form-label small mb-1">Bulk action (all servers)</label>
      <div class="d-flex flex-wrap gap-2">
        <button class="btn btn-sm btn-outline-success" data-ma-bulk="start" type="button"><i class="bi bi-play-fill"></i> Start All</button>
        <button class="btn btn-sm btn-outline-primary" data-ma-bulk="restart" type="button"><i class="bi bi-arrow-clockwise"></i> Restart All</button>
        <button class="btn btn-sm btn-outline-danger" data-ma-bulk="stop" type="button"><i class="bi bi-stop-fill"></i> Stop All</button>
      </div>
    </div>
    <div class="col-12 col-md-3 col-lg-5 text-md-end">
      <button class="btn btn-sm btn-outline-info me-1" id="maConnectAll" type="button"><i class="bi bi-plug"></i> Connect All</button>
      <button class="btn btn-sm btn-outline-secondary" id="maRefresh" type="button"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
    </div>
  </div>
  <p class="text-secondary small mt-2 mb-0">
    <i class="bi bi-info-circle"></i> Per-server: reboot, mail, cron, backup, images, dan <strong>Terminal</strong> (jalankan command SSH langsung dari dashboard).
  </p>
</div>

<div id="maGrid" class="row g-3">
  <div class="col-12 text-secondary text-center py-4">Loading servers…</div>
</div>

<div class="sm-card mt-3">
  <div class="sm-card-head">
    <span><i class="bi bi-hdd-stack"></i> Central Backup Queue</span>
    <span class="badge text-bg-secondary" id="maBackupQueueBadge">—</span>
  </div>
  <p class="text-secondary small mb-2">Semua image server disimpan di <code>storage/server-backups/</code> pada server monitor ini.</p>
  <div class="table-responsive">
    <table class="table sm-table mb-0">
      <thead><tr><th>#</th><th>Server</th><th>Job</th><th>Status</th><th>Result</th></tr></thead>
      <tbody id="maBackupQueueBody">
        <tr><td colspan="5" class="text-secondary text-center py-3">No backup jobs yet.</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- Mail queue modal -->
<div class="modal fade" id="maModalMail" tabindex="-1" aria-labelledby="maModalMailLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content sm-modal">
      <div class="modal-header">
        <h5 class="modal-title" id="maModalMailLabel"><i class="bi bi-envelope me-1"></i> Mail Queue</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="maModalMailBody">
        <div class="text-secondary text-center py-4">Loading…</div>
      </div>
      <div class="modal-footer flex-wrap gap-2" id="maModalMailFooter">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Cron jobs modal -->
<div class="modal fade" id="maModalCron" tabindex="-1" aria-labelledby="maModalCronLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content sm-modal">
      <div class="modal-header">
        <h5 class="modal-title" id="maModalCronLabel"><i class="bi bi-calendar-check me-1"></i> Cron Jobs</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="maModalCronBody">
        <div class="text-secondary text-center py-4">Loading…</div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Server images modal (central storage) -->
<div class="modal fade" id="maModalImages" tabindex="-1" aria-labelledby="maModalImagesLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content sm-modal">
      <div class="modal-header">
        <h5 class="modal-title" id="maModalImagesLabel"><i class="bi bi-hdd me-1"></i> Server Images</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="maModalImagesBody">
        <div class="text-secondary text-center py-4">Loading…</div>
      </div>
      <div class="modal-footer flex-wrap gap-2" id="maModalImagesFooter">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Shell terminal modal -->
<div class="modal fade" id="maModalShell" tabindex="-1" aria-labelledby="maModalShellLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content sm-modal">
      <div class="modal-header">
        <h5 class="modal-title" id="maModalShellLabel"><i class="bi bi-terminal me-1"></i> Terminal</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="d-flex flex-wrap gap-2 mb-2">
          <select class="form-select form-select-sm" id="maShellQuick" style="max-width:280px">
            <option value="">Quick command…</option>
            <option value="hostname &amp;&amp; uptime">hostname &amp; uptime</option>
            <option value="df -h /">df -h /</option>
            <option value="free -h">free -h</option>
            <option value="systemctl status nginx --no-pager -l | head -20">nginx status</option>
            <option value="cyberpanel listWebsitesJson 2>/dev/null | head -c 4000">cyberpanel listWebsitesJson</option>
            <option value="postqueue -p | head -30">mail queue (postqueue)</option>
            <option value="crontab -l 2>/dev/null; ls -la /etc/cron.d 2>/dev/null | head -20">cron overview</option>
          </select>
          <button type="button" class="btn btn-sm btn-outline-secondary" id="maShellClear"><i class="bi bi-eraser"></i> Clear</button>
        </div>
        <pre class="sm-log-view ma-shell-out mb-2" id="maShellOutput">$ Ready. Type a command below.</pre>
        <form id="maShellForm" class="d-flex gap-2" autocomplete="off">
          <div class="input-group">
            <span class="input-group-text text-success font-monospace">$</span>
            <input type="text" class="form-control font-monospace" id="maShellInput" placeholder="e.g. ls -la /home" spellcheck="false" />
            <button class="btn btn-success" type="submit" id="maShellRun"><i class="bi bi-play-fill"></i> Run</button>
          </div>
        </form>
        <p class="form-text mb-0">Command dijalankan via SSH pada server target. Timeout default 60s (max 5 menit).</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

</div>

<script>window.SM_PAGE = 'monitoring-all';</script>
<%- include('partials/layout-close') %>
