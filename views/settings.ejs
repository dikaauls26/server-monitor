<%- include('partials/layout-open') %>

<% if (saved === 'password') { %>
  <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> Password updated successfully.</div>
<% } else if (saved === 'port') { %>
  <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> Port saved to <code>.env</code>. Restart to apply: <code>pm2 restart server-monitor</code>.</div>
<% } else if (saved === 'thresholds') { %>
  <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> Alert thresholds updated.</div>
<% } else if (saved === '2fa-enabled') { %>
  <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> Two-factor authentication enabled.</div>
<% } else if (saved === '2fa-disabled') { %>
  <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> Two-factor authentication disabled.</div>
<% } else if (saved === 'cloudflare') { %>
  <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> Cloudflare settings saved.</div>
<% } else if (saved === 'encrypted') { %>
  <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> SSH credentials encrypted successfully.</div>
<% } else if (saved === 'backup-restored') { %>
  <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> Configuration restored. If the app did not restart automatically, run <code>pm2 restart server-monitor</code>.</div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i> <%= error %></div>
<% } %>

<div class="row g-3">
  <div class="col-12 col-lg-6">
    <div class="sm-card h-100">
      <div class="sm-card-head"><span><i class="bi bi-key"></i> Change Password</span></div>
      <form method="POST" action="/settings/password" autocomplete="off">
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %><%- include('partials/csrf-field') %><% } %>
        <div class="mb-3">
          <label class="form-label">Current password</label>
          <input type="password" class="form-control" name="current_password" required />
        </div>
        <div class="mb-3">
          <label class="form-label">New password</label>
          <input type="password" class="form-control" name="new_password" minlength="8" required />
          <div class="form-text">At least 8 characters.</div>
        </div>
        <div class="mb-3">
          <label class="form-label">Confirm new password</label>
          <input type="password" class="form-control" name="confirm_password" minlength="8" required />
        </div>
        <button class="btn btn-primary"><i class="bi bi-save me-1"></i> Update password</button>
      </form>
    </div>
  </div>

  <div class="col-12 col-lg-6">
    <div class="sm-card mb-3">
      <div class="sm-card-head"><span><i class="bi bi-hdd-network"></i> Change Port</span></div>
      <form method="POST" action="/settings/port">
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %><%- include('partials/csrf-field') %><% } %>
        <div class="mb-3">
          <label class="form-label">HTTP port</label>
          <input type="number" class="form-control" name="port" min="1" max="65535"
                 value="<%= process.env.PORT || 19091 %>" required />
          <div class="form-text">Saved to <code>.env</code>. Requires a restart to take effect.</div>
        </div>
        <button class="btn btn-primary"><i class="bi bi-save me-1"></i> Save port</button>
      </form>
    </div>

    <div class="sm-card">
      <div class="sm-card-head"><span><i class="bi bi-sliders"></i> Alert Thresholds</span></div>
      <form method="POST" action="/settings/thresholds">
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %><%- include('partials/csrf-field') %><% } %>
        <div class="row g-2">
          <div class="col-4">
            <label class="form-label">CPU %</label>
            <input type="number" class="form-control" name="cpu" min="1" max="100" value="<%= thresholds.cpu %>" />
          </div>
          <div class="col-4">
            <label class="form-label">RAM %</label>
            <input type="number" class="form-control" name="ram" min="1" max="100" value="<%= thresholds.ram %>" />
          </div>
          <div class="col-4">
            <label class="form-label">Disk %</label>
            <input type="number" class="form-control" name="disk" min="1" max="100" value="<%= thresholds.disk %>" />
          </div>
        </div>
        <button class="btn btn-primary mt-3"><i class="bi bi-save me-1"></i> Save thresholds</button>
      </form>
    </div>
  </div>
</div>

<div class="sm-card mt-3">
  <div class="sm-card-head">
    <span><i class="bi bi-cloud"></i> Cloudflare DNS</span>
    <% if (cloudflare && cloudflare.configured) { %>
      <span class="sm-pill running"><span class="dot"></span>connected</span>
    <% } else { %>
      <span class="sm-pill stopped"><span class="dot"></span>not configured</span>
    <% } %>
  </div>
  <p class="text-secondary small">
    Used in <strong>Domains</strong> to show A/CNAME records and detect if DNS still points to this server.
    Create token at Cloudflare → My Profile → API Tokens (Zone → DNS → Read).
  </p>
  <form method="POST" action="/settings/cloudflare" autocomplete="off" class="mb-3">
    <% if (typeof csrfToken !== 'undefined' && csrfToken) { %><%- include('partials/csrf-field') %><% } %>
    <div class="row g-3">
      <div class="col-12 col-lg-6">
        <label class="form-label">API Token</label>
        <input type="password" class="form-control" name="api_token" autocomplete="new-password"
               placeholder="<%= cloudflare && cloudflare.configured ? 'Leave blank to keep current token' : 'Cloudflare API token' %>" />
        <% if (cloudflare && cloudflare.configured) { %>
          <div class="form-text">Current: <code><%= cloudflare.tokenPreview %></code> (encrypted in database)</div>
        <% } %>
      </div>
      <div class="col-12 col-lg-6">
        <label class="form-label">Zone ID <span class="text-secondary">(optional)</span></label>
        <input type="text" class="form-control" name="zone_id" value="<%= cloudflare ? cloudflare.zoneId : '' %>"
               placeholder="e.g. 3c70bd1a33e04a49b52e495877090d90" />
        <div class="form-text">Default zone — auto-detect per domain if empty. Find in Cloudflare → domain → Overview → Zone ID.</div>
      </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-3">
      <button class="btn btn-primary" type="submit"><i class="bi bi-save me-1"></i> Save Cloudflare</button>
      <button class="btn btn-outline-info" type="button" id="btnCfTest"><i class="bi bi-plug me-1"></i> Test connection</button>
    </div>
  </form>
  <div id="cfTestResult" class="alert d-none py-2 mb-0" role="alert"></div>
</div>

<div class="sm-card mt-3">
  <div class="sm-card-head">
    <span><i class="bi bi-shield-lock"></i> Two-Factor Authentication (2FA)</span>
    <% if (totpEnabled) { %>
      <span class="sm-pill running"><span class="dot"></span>enabled</span>
    <% } else { %>
      <span class="sm-pill stopped"><span class="dot"></span>disabled</span>
    <% } %>
  </div>

  <% if (backupCodes && backupCodes.length) { %>
    <div class="alert alert-warning py-2">
      <strong>Save these backup codes now.</strong> Each code works once if you lose your phone.
    </div>
    <div class="row g-2 mb-3">
      <% backupCodes.forEach(function (code) { %>
        <div class="col-6 col-md-3"><code class="user-select-all"><%= code %></code></div>
      <% }); %>
    </div>
  <% } %>

  <% if (totpSetup && qrDataUrl) { %>
    <p class="text-secondary small">Scan this QR code with Google Authenticator, Authy, or any TOTP app.</p>
    <div class="text-center mb-3">
      <img src="<%= qrDataUrl %>" alt="2FA QR code" width="220" height="220" class="border rounded" />
    </div>
    <form method="POST" action="/settings/2fa/enable" autocomplete="off">
      <% if (typeof csrfToken !== 'undefined' && csrfToken) { %><%- include('partials/csrf-field') %><% } %>
      <div class="mb-3">
        <label class="form-label">Enter 6-digit code to confirm</label>
        <input type="text" class="form-control" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required />
      </div>
      <button class="btn btn-success"><i class="bi bi-shield-check me-1"></i> Enable 2FA</button>
    </form>
  <% } else if (totpEnabled) { %>
    <p class="text-secondary mb-3">Sign-in requires your authenticator app code after password.</p>
    <form method="POST" action="/settings/2fa/disable" autocomplete="off">
      <% if (typeof csrfToken !== 'undefined' && csrfToken) { %><%- include('partials/csrf-field') %><% } %>
      <div class="row g-2">
        <div class="col-md-6">
          <label class="form-label">Current password</label>
          <input type="password" class="form-control" name="current_password" required />
        </div>
        <div class="col-md-6">
          <label class="form-label">Authenticator or backup code</label>
          <input type="text" class="form-control" name="code" required />
        </div>
      </div>
      <button class="btn btn-outline-danger mt-3"><i class="bi bi-shield-x me-1"></i> Disable 2FA</button>
    </form>
  <% } else { %>
    <p class="text-secondary mb-3">Add an extra layer of security using an authenticator app on your phone.</p>
    <form method="POST" action="/settings/2fa/setup">
      <% if (typeof csrfToken !== 'undefined' && csrfToken) { %><%- include('partials/csrf-field') %><% } %>
      <button class="btn btn-primary"><i class="bi bi-qr-code me-1"></i> Set up 2FA</button>
    </form>
  <% } %>
</div>

<div class="sm-card mt-3">
  <div class="sm-card-head">
    <span><i class="bi bi-lock-fill"></i> SSH Credential Encryption</span>
    <% if (credentialStatus && credentialStatus.fullyEncrypted) { %>
      <span class="sm-pill running"><span class="dot"></span>encrypted</span>
    <% } else { %>
      <span class="sm-pill stopped"><span class="dot"></span><%= credentialStatus ? credentialStatus.plaintextSecrets + ' plain' : 'unknown' %></span>
    <% } %>
  </div>
  <p class="text-secondary small mb-2">
    SSH passwords and private keys are stored in SQLite using AES-256-GCM.
    New servers are encrypted automatically when <code>ENCRYPTION_KEY</code> is set in <code>.env</code>.
  </p>
  <ul class="small text-secondary mb-3">
    <li>Servers configured: <strong><%= credentialStatus ? credentialStatus.servers : 0 %></strong></li>
    <li>Encrypted secrets: <strong><%= credentialStatus ? credentialStatus.encryptedSecrets : 0 %></strong></li>
    <li>Plaintext secrets remaining: <strong><%= credentialStatus ? credentialStatus.plaintextSecrets : 0 %></strong></li>
    <li>Encryption key: <strong><%= credentialStatus && credentialStatus.keyConfigured ? 'configured' : 'missing — set ENCRYPTION_KEY in .env' %></strong></li>
  </ul>
  <div id="encryptResult" class="alert d-none py-2 mb-3" role="alert"></div>
  <button class="btn btn-warning" id="btnEncryptSsh" type="button"
          <%= (credentialStatus && credentialStatus.fullyEncrypted) ? 'disabled' : '' %>>
    <i class="bi bi-shield-lock me-1"></i> Encrypt all SSH credentials now
  </button>
  <p class="form-text mt-2 mb-0">Use this once after upgrade if you had servers added before encryption was enabled.</p>
</div>

<div class="sm-card mt-3">
  <div class="sm-card-head">
    <span><i class="bi bi-archive"></i> Configuration Backup</span>
    <span class="text-secondary small">Snapshot / restore</span>
  </div>
  <p class="text-secondary small mb-3">
    One-click backup of important configuration: SQLite database (users, SSH servers, settings, Cloudflare token),
    active sessions, and <code>.env</code>. Stored as compressed archives in <code>storage/backups/</code>.
  </p>
  <div id="backupActionResult" class="alert d-none py-2 mb-3" role="alert"></div>
  <div class="row g-2 align-items-end mb-3">
    <div class="col-12 col-md-8">
      <label class="form-label small mb-1">Note <span class="text-secondary">(optional)</span></label>
      <input type="text" class="form-control form-control-sm" id="backupNote" maxlength="200" placeholder="e.g. Before server migration" />
    </div>
    <div class="col-12 col-md-4">
      <button class="btn btn-primary w-100" type="button" id="btnCreateBackup">
        <i class="bi bi-cloud-download me-1"></i> Create backup now
      </button>
    </div>
  </div>
  <div class="table-responsive">
    <table class="table sm-table mb-0">
      <thead>
        <tr>
          <th>Backup</th><th>Size</th><th>Note</th><th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody id="backupListBody">
        <tr><td colspan="4" class="text-secondary text-center py-3">Loading backups…</td></tr>
      </tbody>
    </table>
  </div>
  <p class="form-text mt-2 mb-0">Restore replaces the database and <code>.env</code>. A safety snapshot is created automatically before restore. Max <%= 15 %> archives kept.</p>
</div>

<div class="sm-card mt-3">
  <div class="sm-card-head">
    <span><i class="bi bi-shield-fill-check"></i> HTTPS / SSL</span>
    <% if (secureCookie) { %>
      <span class="sm-pill running"><span class="dot"></span>secure cookies on</span>
    <% } else { %>
      <span class="sm-pill stopped"><span class="dot"></span>http only</span>
    <% } %>
  </div>
  <p class="text-secondary small mb-2">
    For production, put Nginx in front with SSL. Without a domain, use a self-signed certificate (browser warning)
    or a free subdomain (DuckDNS) with Let's Encrypt.
  </p>
  <div class="small text-secondary mb-3">
    <p class="mb-2"><strong>Option A — no domain (IP only):</strong></p>
    <code class="user-select-all d-block mb-2">bash setup-ssl-selfsigned.sh</code>
    <p class="mb-2">Then open <code>https://YOUR_SERVER_IP/</code> and accept the browser warning once.</p>
    <p class="mb-2"><strong>Option B — free subdomain + trusted SSL (CyberPanel servers):</strong></p>
    <ol class="mb-2">
      <li>Register at <a href="https://www.duckdns.org" target="_blank" rel="noopener">duckdns.org</a> → set subdomain IP</li>
      <li>If port 80 is used by CyberPanel, use DNS challenge (not setup-ssl.sh):<br>
        <code class="user-select-all">bash setup-ssl-duckdns.sh name.duckdns.org YOUR_TOKEN email 8443</code></li>
      <li>If port 80 is free: <code class="user-select-all">bash setup-ssl.sh name.duckdns.org email</code></li>
    </ol>
    <p class="mb-0"><strong>Option C — keep HTTP:</strong> use <code>http://IP:<%= process.env.PORT || 19091 %></code> + firewall restrict to your IP + 2FA enabled.</p>
  </div>
  <% if (publicUrl) { %>
    <p class="small mb-0">Public URL: <a href="<%= publicUrl %>" target="_blank" rel="noopener"><%= publicUrl %></a></p>
  <% } %>
</div>

<div class="sm-card mt-3">
  <div class="sm-card-head"><span><i class="bi bi-box-arrow-right"></i> Session</span></div>
  <p class="text-secondary mb-3">End your current session and return to the login screen.</p>
  <a href="/logout" class="btn btn-outline-danger"><i class="bi bi-box-arrow-right me-1"></i> Logout</a>
</div>

<script>
  window.SM_PAGE = 'settings';
  (function () {
    var cfBtn = document.getElementById('btnCfTest');
    var cfBox = document.getElementById('cfTestResult');
    if (cfBtn) cfBtn.addEventListener('click', function () {
      cfBtn.disabled = true;
      fetch('/api/cloudflare/test', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-CSRF-Token': (document.querySelector('meta[name="csrf-token"]') || {}).content || ''
        },
        credentials: 'same-origin',
        body: '{}',
      }).then(function (r) { return r.json(); }).then(function (res) {
        if (cfBox) {
          cfBox.className = 'alert py-2 mb-0 ' + (res.ok ? 'alert-success' : 'alert-danger');
          var msg = res.message || res.error || (res.ok ? 'OK' : 'Failed');
          if (res.zone && res.zone.name) msg += ' Zone: ' + res.zone.name;
          cfBox.textContent = msg;
          cfBox.classList.remove('d-none');
        }
        cfBtn.disabled = false;
      }).catch(function () {
        if (cfBox) {
          cfBox.className = 'alert alert-danger py-2 mb-0';
          cfBox.textContent = 'Request failed.';
          cfBox.classList.remove('d-none');
        }
        cfBtn.disabled = false;
      });
    });
  })();
  (function () {
    var btn = document.getElementById('btnEncryptSsh');
    var box = document.getElementById('encryptResult');
    if (!btn) return;
    btn.addEventListener('click', function () {
      if (!confirm('Encrypt all stored SSH passwords and private keys now?')) return;
      btn.disabled = true;
      fetch('/api/security/encrypt-credentials', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-CSRF-Token': (document.querySelector('meta[name="csrf-token"]') || {}).content || ''
        },
        credentials: 'same-origin',
        body: '{}',
      })
        .then(function (r) { return r.json(); })
        .then(function (res) {
          if (box) {
            box.className = 'alert py-2 mb-3 ' + (res.ok ? 'alert-success' : 'alert-danger');
            box.textContent = res.message || res.error || (res.ok ? 'Done' : 'Failed');
            box.classList.remove('d-none');
          }
          if (res.ok) setTimeout(function () { window.location.href = '/settings?saved=encrypted'; }, 800);
          else btn.disabled = false;
        })
        .catch(function () {
          if (box) {
            box.className = 'alert alert-danger py-2 mb-3';
            box.textContent = 'Request failed.';
            box.classList.remove('d-none');
          }
          btn.disabled = false;
        });
    });
  })();
  (function () {
    var csrf = (document.querySelector('meta[name="csrf-token"]') || {}).content || '';
    var listBody = document.getElementById('backupListBody');
    var resultBox = document.getElementById('backupActionResult');
    var createBtn = document.getElementById('btnCreateBackup');
    var noteInput = document.getElementById('backupNote');

    function showBackupResult(ok, msg) {
      if (!resultBox) return;
      resultBox.className = 'alert py-2 mb-3 ' + (ok ? 'alert-success' : 'alert-danger');
      resultBox.textContent = msg;
      resultBox.classList.remove('d-none');
    }

    function fmtSize(bytes) {
      if (!bytes) return '—';
      var units = ['B', 'KB', 'MB', 'GB'];
      var i = 0; var n = Number(bytes);
      while (n >= 1024 && i < units.length - 1) { n /= 1024; i++; }
      return (n < 10 ? n.toFixed(1) : Math.round(n)) + ' ' + units[i];
    }

    function renderBackups(backups) {
      if (!listBody) return;
      if (!backups || !backups.length) {
        listBody.innerHTML = '<tr><td colspan="4" class="text-secondary text-center py-3">No backups yet.</td></tr>';
        return;
      }
      listBody.innerHTML = backups.map(function (b) {
        var when = b.createdAt ? new Date(b.createdAt).toLocaleString() : '—';
        return '<tr>' +
          '<td><div class="fw-semibold small">' + b.id + '</div><div class="text-secondary small">' + when + '</div></td>' +
          '<td class="small">' + fmtSize(b.size) + '</td>' +
          '<td class="small text-break">' + (b.note || '—') + '</td>' +
          '<td class="text-end text-nowrap">' +
            '<a class="btn btn-sm btn-outline-info me-1" href="/api/backup/' + encodeURIComponent(b.id) + '/download"><i class="bi bi-download"></i></a>' +
            '<button type="button" class="btn btn-sm btn-outline-warning me-1" data-backup-restore="' + b.id + '" title="Restore"><i class="bi bi-arrow-counterclockwise"></i></button>' +
            '<button type="button" class="btn btn-sm btn-outline-danger" data-backup-delete="' + b.id + '" title="Delete"><i class="bi bi-trash"></i></button>' +
          '</td></tr>';
      }).join('');
    }

    function loadBackups() {
      return fetch('/api/backup', {
        headers: { 'Accept': 'application/json', 'X-CSRF-Token': csrf },
        credentials: 'same-origin'
      }).then(function (r) { return r.json(); }).then(function (res) {
        if (res.ok) renderBackups(res.backups || []);
        else if (listBody) listBody.innerHTML = '<tr><td colspan="4" class="text-danger text-center py-3">' + (res.error || 'Failed to load backups.') + '</td></tr>';
      }).catch(function () {
        if (listBody) listBody.innerHTML = '<tr><td colspan="4" class="text-danger text-center py-3">Request failed.</td></tr>';
      });
    }

    if (createBtn) createBtn.addEventListener('click', function () {
      createBtn.disabled = true;
      fetch('/api/backup/create', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-CSRF-Token': csrf
        },
        credentials: 'same-origin',
        body: JSON.stringify({ note: noteInput ? noteInput.value : '' })
      }).then(function (r) { return r.json(); }).then(function (res) {
        showBackupResult(res.ok, res.message || res.error || (res.ok ? 'Backup created.' : 'Failed.'));
        if (res.ok) {
          if (noteInput) noteInput.value = '';
          loadBackups();
        }
        createBtn.disabled = false;
      }).catch(function () {
        showBackupResult(false, 'Request failed.');
        createBtn.disabled = false;
      });
    });

    if (listBody) listBody.addEventListener('click', function (e) {
      var delBtn = e.target.closest ? e.target.closest('[data-backup-delete]') : null;
      if (delBtn) {
        e.preventDefault();
        var delId = delBtn.getAttribute('data-backup-delete');
        if (!confirm('Delete backup "' + delId + '"?')) return;
        delBtn.disabled = true;
        fetch('/api/backup/' + encodeURIComponent(delId), {
          method: 'DELETE',
          headers: { 'Accept': 'application/json', 'X-CSRF-Token': csrf },
          credentials: 'same-origin'
        }).then(function (r) { return r.json(); }).then(function (res) {
          showBackupResult(res.ok, res.message || res.error || 'Done.');
          if (res.ok) loadBackups(); else delBtn.disabled = false;
        }).catch(function () {
          showBackupResult(false, 'Request failed.');
          delBtn.disabled = false;
        });
        return;
      }
      var restoreBtn = e.target.closest ? e.target.closest('[data-backup-restore]') : null;
      if (restoreBtn) {
        e.preventDefault();
        var restoreId = restoreBtn.getAttribute('data-backup-restore');
        var typed = prompt('RESTORE will replace database and .env.\n\nType this backup id to confirm:\n' + restoreId);
        if (typed !== restoreId) {
          if (typed !== null) showBackupResult(false, 'Restore cancelled — backup id did not match.');
          return;
        }
        restoreBtn.disabled = true;
        fetch('/api/backup/' + encodeURIComponent(restoreId) + '/restore', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-CSRF-Token': csrf
          },
          credentials: 'same-origin',
          body: JSON.stringify({ confirm: restoreId })
        }).then(function (r) { return r.json(); }).then(function (res) {
          showBackupResult(res.ok, res.message || res.error || 'Done.');
          if (res.ok) {
            setTimeout(function () { window.location.href = '/settings?saved=backup-restored'; }, 1200);
          } else {
            restoreBtn.disabled = false;
          }
        }).catch(function () {
          showBackupResult(false, 'Request failed.');
          restoreBtn.disabled = false;
        });
      }
    });

    loadBackups();
  })();
</script>
<%- include('partials/layout-close') %>
