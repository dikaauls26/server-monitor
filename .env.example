# ==========================================================
# Server Monitor - Environment Configuration
# Copy this file to .env (install.sh does this automatically)
# ==========================================================

# HTTP port the dashboard listens on. Change this and restart.
PORT=19091

# Host/interface to bind to. 0.0.0.0 = all interfaces.
HOST=0.0.0.0

# Environment: production | development
NODE_ENV=production

# Secret used to sign session cookies.
# install.sh generates a strong random value automatically.
SESSION_SECRET=change_me_to_a_long_random_string

# Session idle timeout in minutes (auto logout after inactivity).
SESSION_TIMEOUT_MINUTES=30

# Set to true ONLY when serving over HTTPS (cookies become secure-only).
SECURE_COOKIE=false

# Public HTTPS URL after running setup-ssl.sh (optional).
# PUBLIC_URL=https://monitor.example.com

# AES-256 key for encrypting SSH passwords/private keys in SQLite.
# install.sh generates a strong random value automatically.
ENCRYPTION_KEY=change_me_encryption_key

# ----------------------------------------------------------
# Default admin account (only used the FIRST time you seed).
# The password is hashed with bcrypt and stored in SQLite.
# It is NEVER stored in plain text in the database.
# ----------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Jakarta1412@@

# ----------------------------------------------------------
# Alert thresholds (percent). Alerts fire when usage exceeds these.
# ----------------------------------------------------------
ALERT_CPU_THRESHOLD=90
ALERT_RAM_THRESHOLD=90
ALERT_DISK_THRESHOLD=90

# Polling interval used by background alert checker (seconds).
ALERT_POLL_SECONDS=30

# ----------------------------------------------------------
# Log file locations to read for the Logs page.
# Comma-separated list of "Label:/absolute/path" pairs.
# ----------------------------------------------------------
SYSTEM_LOG_PATHS="Syslog:/var/log/syslog,Auth:/var/log/auth.log"
ERROR_LOG_PATHS="Nginx Error:/var/log/nginx/error.log,App Error:./logs/error.log"
