# Force LF line endings for shell scripts so they run correctly on Linux,
# even when the repo is edited/committed from Windows.
*.sh text eol=lf
install.sh text eol=lf
start.sh text eol=lf
stop.sh text eol=lf
update.sh text eol=lf

# Normalize common text files
*.js text
*.json text
*.ejs text
*.css text
*.md text

# Treat the SQLite DB as binary if it ever sneaks in
*.db binary
